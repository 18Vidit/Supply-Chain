# Supply Chain Risk Intelligence — Environment Variables
# Copy this file to .env and fill in your values

# AirNow API Key (get yours free at https://www.airnowapi.org/)
AIRNOW_API_KEY=

# Gemini API Key (get yours free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=offline

# Optional live traffic provider
TOMTOM_API_KEY=

# Optional Firebase Realtime Database integration
FIREBASE_DATABASE_URL=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CREDENTIALS_JSON=

# Provider cache and timeout knobs
CONDITIONS_CACHE_TTL_SEC=600
CONDITIONS_TIMEOUT_SEC=5
